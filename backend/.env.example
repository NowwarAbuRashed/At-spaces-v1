NODE_ENV=development
HOST=0.0.0.0
PORT=3000

# Database / Cache
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/atspaces?schema=public
REDIS_URL=redis://localhost:6379

# JWT / Sessions
JWT_ACCESS_SECRET=replace_with_access_secret_min_32_chars_for_production_use
JWT_REFRESH_SECRET=replace_with_refresh_secret_min_32_chars_for_production_use
ACCESS_TOKEN_TTL_MIN=15
REFRESH_TOKEN_TTL_DAYS=14
ADMIN_INACTIVITY_TTL_MIN=30

# Cookies
COOKIE_NAME_REFRESH=atspaces_rt
COOKIE_DOMAIN=
COOKIE_SECURE=false
COOKIE_SAMESITE=Strict

# Swagger / API docs
ENABLE_SWAGGER=true
SWAGGER_PATH=api/docs

# CORS / Proxy / Logging
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000
CORS_ALLOW_CREDENTIALS=true
TRUST_PROXY=
ENABLE_REQUEST_LOGGING=true
LOG_LEVEL=info

# Security
HCAPTCHA_SECRET=replace_with_hcaptcha_secret
HCAPTCHA_SITE_KEY=replace_with_hcaptcha_site_key
HCAPTCHA_TEST_BYPASS=false
HMAC_APPROVAL_REQUESTS_KEY=replace_with_hmac_approval_key_min_32_chars_for_production
HMAC_VENDOR_NOTIFICATIONS_KEY=replace_with_hmac_vendor_key_min_32_chars_for_production

# AWS SES
AWS_REGION=us-east-1
AWS_SES_FROM_EMAIL=no-reply@example.com
AWS_SES_SECURITY_TEAM_INBOX=security@example.com
SES_FROM_EMAIL=no-reply@example.com
SES_SECURITY_TEAM_INBOX=security@example.com

# AWS S3 reports
AWS_S3_BUCKET_PRIVATE_REPORTS=atspaces-private-reports
AWS_S3_PRESIGN_EXP_SECONDS=300
AWS_S3_SSE_MODE=SSE-S3
AWS_S3_KMS_KEY_ID=
S3_BUCKET_PRIVATE_REPORTS=atspaces-private-reports
S3_PRESIGN_EXP_SECONDS=300
S3_SSE_MODE=SSE-S3
S3_KMS_KEY_ID=
REPORT_EXPORT_MOCK=false

# Upload URL base
UPLOAD_PUBLIC_BASE_URL=https://uploads.local
UPLOADS_S3_BUCKET=atspaces-uploads

# Seed admin (development use)
ADMIN_SEED_FULL_NAME=At Spaces Admin
ADMIN_SEED_EMAIL=admin@example.com
ADMIN_SEED_PASSWORD=change_this_seed_password
ADMIN_SEED_TOTP_SECRET=replace_with_admin_seed_totp_secret
